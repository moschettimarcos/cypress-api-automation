{
  "apiUrl": "https://jsonplaceholder.typicode.com",
  "apiVersion": "v1",
  "timeout": 10000,
  "retryOnNetworkFailure": true,
  "retryOnStatusCodeFailure": false,
  "auth": {
    "bearerToken": "your-bearer-token-here",
    "apiKey": "your-api-key-here",
    "basicAuth": {
      "username": "test-user",
      "password": "test-password"
    }
  },
  "endpoints": {
    "users": "/users",
    "posts": "/posts",
    "comments": "/comments",
    "albums": "/albums",
    "photos": "/photos",
    "todos": "/todos"
  }
}
